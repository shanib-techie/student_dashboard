# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────

# Your Supabase project URL (safe to expose — used in browser too)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon key — safe for browser, limited RLS-controlled access
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key — SERVER ONLY, never expose to the browser
# Used in lib/supabase.ts for server-side data fetching
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
